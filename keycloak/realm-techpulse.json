{
  "realm": "techpulse",
  "displayName": "TechPulse Academy",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "requiredCredentials": [
    "password"
  ],
  "roles": {
    "realm": [
      {
        "name": "org-admin",
        "description": "Organization administrator / registrar"
      },
      {
        "name": "student",
        "description": "Student user"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "org-info",
      "description": "Organization info claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "org_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "org_id",
            "claim.value": "techpulse",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "org_name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "org_name",
            "claim.value": "TechPulse Academy",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "openid",
    "profile",
    "email",
    "org-info"
  ],
  "clients": [
    {
      "clientId": "course-manager-ui",
      "name": "TechPulse Course Manager",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "https://course-manager-ui-certchain-techpulse.*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "org-info"
      ],
      "protocolMappers": [
        {
          "name": "cert-admin-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "cert-admin-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "lightweight.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "cert-admin-api",
      "name": "TechPulse Admin API",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "openid",
        "profile",
        "org-info"
      ]
    },
    {
      "clientId": "broker-client",
      "name": "Central KC Broker Client",
      "description": "Used by central KC to broker authentication for students",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "secret": "broker-secret-techpulse",
      "redirectUris": [
        "https://keycloak-certchain.*"
      ],
      "webOrigins": [
        "*"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "admin@techpulse.demo",
      "firstName": "Admin",
      "lastName": "TechPulse",
      "email": "admin@techpulse.demo",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "org-admin"
      ]
    },
    {
      "username": "student01@techpulse.demo",
      "firstName": "Alice",
      "lastName": "Chen",
      "email": "student01@techpulse.demo",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "student",
          "temporary": false
        }
      ],
      "realmRoles": [
        "student"
      ]
    },
    {
      "username": "student02@techpulse.demo",
      "firstName": "Bob",
      "lastName": "Martinez",
      "email": "student02@techpulse.demo",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "student",
          "temporary": false
        }
      ],
      "realmRoles": [
        "student"
      ]
    }
  ]
}